# ============================================================
# Legends EOR — environment variables
# Copy to .env and fill in. The site runs without these (homepage,
# calculator); they enable the CMS, lead storage and GF forwarding.
# ============================================================

# --- Supabase (Dashboard → Project Settings → API) ---
SUPABASE_URL=
SUPABASE_KEY=            # anon/public key (used by @nuxtjs/supabase)
SUPABASE_SERVICE_KEY=    # service_role key (server-only: lead inserts)

# --- Gravity Forms forwarding (WP admin → Forms → Settings → REST API) ---
# Form IDs are fixed in code: header 29, footer 28, popup 31.
GF_BASE_URL=https://legendseor.com
GF_CONSUMER_KEY=
GF_CONSUMER_SECRET=
